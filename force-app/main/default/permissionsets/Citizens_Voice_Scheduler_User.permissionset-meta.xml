    <hasActivationRequired>false</hasActivationRequired>
    <label>Citizens Voice Scheduler User</label>
    <classAccesses>
        <apexClass>CitizensSchedulerService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CitizensAgentScheduleAppointment</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
